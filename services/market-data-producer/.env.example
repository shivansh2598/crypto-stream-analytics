# Kafka bootstrap servers (comma-separated)
KAFKA_BROKERS=localhost:9093

# Kafka topic to publish trade events to
KAFKA_TOPIC=crypto_trades

# Symbols to subscribe from Binance (comma-separated, case-insensitive)
SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT

# Reconnect delay in seconds after WebSocket disconnection
RECONNECT_DELAY=3
